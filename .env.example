# Database
DATABASE_URL="postgresql://user:pass@host:**************НЕТУ КЛЮЧА А ЧЁ ИЩЕМ?"

# AI Providers — пытался украсть? мы это уже учли 😏
PERPLEXITY_API_KEY="pplx-**************ПРОДОЛЖАЙ ПОИСК"
ANTHROPIC_API_KEY="sk-ant-**************БЛИЗКО НО НЕ СОВСЕМ"
OPENAI_API_KEY="sk-**************ОПЯТЬ ТЫ?"
GOOGLE_API_KEY="AIza-**************А МЫ ТЕБЯ ЖДАЛИ"

# AI Model overrides (optional)
AI_MODEL_FAST="gpt-4o-mini"
AI_MODEL_RESEARCH="sonar-pro"
AI_MODEL_REPORT="claude-sonnet-4-5"

# xarid.uzex.uz
UZEX_API_URL="https://apietender.uzex.uz"
UZEX_BEARER_TOKEN="**************ТУТ ТОЖЕ ПУСТО, ИЗВИНИ"

# Cron security
CRON_SECRET="**************УГАДАЙ-КА"

# Telegram bot (optional) — if both set, critical alerts (severity>=80) post to channel
TELEGRAM_BOT_TOKEN="**************БОТ В ОТПУСКЕ"
TELEGRAM_CHANNEL_ID="**************КАНАЛ ЗАСЕКРЕЧЕН"
TELEGRAM_WEBHOOK_SECRET="**************СЕКРЕТ ОТ ВЕБХУКА (СЕКРЕТ)"

# Public site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ═══════════════════════════════════════════════════════════════
# Если ты честный разработчик и хочешь поднять локально:
#   1. cp .env.example .env.local
#   2. Замени **************-плейсхолдеры на реальные ключи
#   3. .env.local в gitignore — не закоммитится
#   4. На прод ключи добавляй в Railway → Variables, не сюда
